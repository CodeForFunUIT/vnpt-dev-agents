# ─────────────────────────────────────────────
# MCP Jira Agent — Environment Variables
# Copy file này thành .env và điền vào
# KHÔNG commit file .env lên git!
# ─────────────────────────────────────────────

# Jira Configuration
# URL gốc của Jira Server (không có dấu / ở cuối)
JIRA_BASE_URL=https://your-jira-server.example.com

# Personal Access Token — lấy tại:
# Jira → Profile → Personal Access Tokens → Create Token
JIRA_PAT=YOUR_PERSONAL_ACCESS_TOKEN

# (Optional) Project key mặc định nếu chỉ làm 1 project
JIRA_DEFAULT_PROJECT=MYPROJECT

# ─────────────────────────────────────────────
# Team Context
# ─────────────────────────────────────────────
# Đường dẫn tuyệt đối đến TEAM_CONTEXT.md
# Mặc định: tự tìm trong thư mục gốc của project
# Chỉ cần set nếu để file ở chỗ khác (VD: shared folder)

TEAM_CONTEXT_PATH=./docs/TEAM_CONTEXT.md
SECURITY_PATTERNS=./docs/SECURITY_PATTERNS.md
GWT_TEMPLATE_GUIDE=./docs/GWT_TEMPLATE_GUIDE.md

# ─────────────────────────────────────────────
# FEEDBACK LOOP — BỔ SUNG #5
# ─────────────────────────────────────────────

# Nơi lưu feedback (mặc định: feedback-store.json trong thư mục chạy)
# Có thể override nếu muốn lưu ở chỗ khác
FEEDBACK_STORE_PATH=./feedback-store.json
# ─────────────────────────────────────────────
# Metrics Store
# ─────────────────────────────────────────────
METRICS_STORE_PATH=./metrics-store.json